{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "validate": "npm run lint",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.config.ts tests/integration",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:coverage": "vitest run --coverage",
    "test:run": "npm run test:unit",
    "type-check": "tsc --noEmit",
    "prepare": "husky",
    "db:seed": "tsx scripts/db/seed.ts",
    "compliance:cleanup": "tsx scripts/compliance/cleanup.ts",
    "compliance:gdpr-delete": "tsx scripts/compliance/gdpr-delete.ts",
    "compliance:data-export": "tsx scripts/compliance/data-export.ts",
    "init-infrastructure": "tsx multi-agent-system/scripts/initialize-infrastructure.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "chart.js": "^4.5.1",
    "next": "16.2.0",
    "papaparse": "^5.5.3",
    "react": "19.2.3",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
